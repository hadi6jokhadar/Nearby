{
  "name": "nearby",
  "version": "1.0.5",
  "description": "Floating team presence widget — no cloud required",
  "main": "electron.js",
  "private": true,
  "author": "Hady Joukhadar <m_cuhadar@yousale.com>",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --config electron-builder.config.js",
    "dist:win": "npm run build && electron-builder --win --config electron-builder.config.js",
    "dist:mac": "npm run build && electron-builder --mac --config electron-builder.config.js",
    "dist:linux": "npm run build && electron-builder --linux --config electron-builder.config.js",
    "release": "node release.mjs",
    "release:minor": "node release.mjs minor",
    "release:major": "node release.mjs major",
    "release:retag": "node release.mjs --retag"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "localtunnel": "^2.0.2",
    "uuid": "^9.0.1",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  }
}
